rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Generated CVs / documents — users can only read their own paid docs
    match /generated_cvs/{documentId} {
      allow read: if request.auth != null
                  && resource.data.userEmail == request.auth.token.email;
      allow create: if false; // Only server-side (API routes) can create
      allow update: if false; // Only server-side (webhook) can update
      allow delete: if false;
    }

    // Purchases — users can only read their own
    match /purchases/{purchaseId} {
      allow read: if request.auth != null
                  && resource.data.userEmail == request.auth.token.email;
      allow create: if false; // Only server-side (webhook) can create
      allow update, delete: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
